# ============================================================
# Windchill API — Umgebungsvariablen
# Kopieren nach .env und anpassen. Niemals .env committen!
# ============================================================

# --- Windchill Server ---
WRS_BASE_URL=https://plm-prod.neuhausen.balluff.net/Windchill
WRS_ODATA_VERSION=v6

# --- Service Account ---
# Zum Entwickeln/Testen: Creator10 als Username und Passwort verwenden.
# Im Produktivbetrieb: dedizierten Service Account mit Read-Rechten anlegen.
WRS_USERNAME=Creator10
WRS_PASSWORD=Creator10

# TLS-Zertifikat: false für interne Systeme mit Self-Signed Certs
WRS_VERIFY_TLS=false

# --- Cache ---
CACHE_TTL_SECONDS=60
CACHE_MAX_SIZE=1000

# --- API-Schutz ---
# Eigenen API-Key erzeugen: python -c "import secrets; print(secrets.token_hex(32))"
# Leer lassen um API-Key-Auth zu deaktivieren (nur Session-Auth aktiv)
API_KEY=

# --- Performance-Logging ---
LOG_TIMING=true

# --- Session (Frontend) ---
SESSION_TTL_SECONDS=3600

# --- Azure AD (optional) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=